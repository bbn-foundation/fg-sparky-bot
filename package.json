{
  "name": "fg-sparky-bot",
  "description": "Source code for the FG sparky bot, inspired by the GD discord sparky bot",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later",
  "version": "1.3.7",
  "scripts": {
    "dev": "bun run --hot --watch src/main.ts",
    "build": "bun build src/main.ts --production --sourcemap --target=bun --outdir=dist",
    "lint": "oxlint . --type-check --type-aware --ignore-path=.gitignore",
    "lint:fix": "oxlint --type-check --type-aware --fix --fix-suggestions . --ignore-path=.gitignore",
    "fmt": "dprint fmt",
    "typecheck": "tsgo -p tsconfig.json",
    "kit": "drizzle-kit"
  },
  "dependencies": {
    "@sapphire/discord.js-utilities": "catalog:discord",
    "@sapphire/result": "catalog:utils",
    "bufferutil": "catalog:discord",
    "chalk": "catalog:utils",
    "commander": "catalog:utils",
    "cronbake": "catalog:utils",
    "discord.js": "catalog:discord",
    "drizzle-orm": "catalog:db",
    "zod": "catalog:types",
    "winston": "catalog:utils"
  },
  "devDependencies": {
    "@types/bun": "catalog:types",
    "@types/node": "catalog:types",
    "@typescript/native-preview": "catalog:types",
    "dprint": "catalog:linting",
    "oxlint": "catalog:linting",
    "oxlint-tsgolint": "catalog:linting",
    "drizzle-kit": "catalog:db"
  },
  "workspaces": {
    "catalogs": {
      "db": {
        "drizzle-orm": "1.0.0-beta.19",
        "drizzle-kit": "^0.31.10"
      },
      "discord": {
        "@sapphire/discord.js-utilities": "^7.3.3",
        "bufferutil": "^4.1.0",
        "discord.js": "^14.26.0"
      },
      "linting": {
        "dprint": "^0.53.2",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.19.0"
      },
      "types": {
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "@typescript/native-preview": "7.0.0-dev.20260401.1",
        "zod": "^4.3.6"
      },
      "utils": {
        "@sapphire/result": "^2.8.0",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "cronbake": "^0.4.0",
        "winston": "^3.19.0"
      }
    }
  }
}
